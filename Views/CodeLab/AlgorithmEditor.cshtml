@{
    ViewBag.Title = "Algorithm Lab";
}

<!-- CodeMirror Core -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.12/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.12/theme/dracula.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.12/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.12/mode/clike/clike.min.js"></script>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold m-0"><i class="fa fa-microchip text-danger me-2"></i>Algorithm Lab</h4>
        <div class="d-flex gap-2">
            <select id="langSelect" class="form-select form-select-sm rounded-pill" style="width: 150px;" onchange="updateEditorMode()">
                <option value="51">C# (Mono)</option>
                <option value="54">C++ (GCC)</option>
            </select>
            <button onclick="compileCode()" class="btn btn-danger px-4 rounded-pill shadow-sm">
                <i class="fa fa-play me-2"></i>Compile & Run
            </button>
            <button onclick="exportCode()" class="btn btn-outline-dark px-3 rounded-pill">
                <i class="fa fa-download me-2"></i>Export
            </button>
            <a href="@Url.Action("Index")" class="btn btn-outline-secondary rounded-pill">Înapoi</a>
        </div>
    </div>

    <div class="row" style="height: 75vh;">
        <!-- Zona de Cod -->
        <div class="col-md-7 h-100">
            <div class="card h-100 border-0 shadow-sm overflow-hidden">
                <textarea id="codeEditor">using System;

public class Program {
    public static void Main() {
        Console.WriteLine("Salut Mentora! Introdu codul tău aici.");
    }
}</textarea>
            </div>
        </div>

        <!-- Terminalul (Output) -->
        <div class="col-md-5 h-100 d-flex flex-column">
            <div class="card flex-grow-1 border-0 shadow-sm bg-black p-3 overflow-auto" id="terminal" style="font-family: 'Consolas', monospace; font-size: 13px; color: #00ff00; border: 2px solid #333 !important;">
                <div class="text-muted">> Waiting for build command...</div>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Inițializare Editor
    var editor = CodeMirror.fromTextArea(document.getElementById("codeEditor"), {
        mode: "text/x-csharp",
        theme: "dracula",
        lineNumbers: true,
        matchBrackets: true,
        autoCloseBrackets: true
    });

    // 2. Schimbare limbaj în timp real
    function updateEditorMode() {
        const lang = document.getElementById('langSelect').value;
        if(lang === "54") {
            editor.setOption("mode", "text/x-c++src");
            if(editor.getValue().includes("Console.WriteLine")) {
                editor.setValue("#include <iostream>\n\nint main() {\n    std::cout << \"Salut din C++!\";\n    return 0;\n}");
            }
        } else {
            editor.setOption("mode", "text/x-csharp");
        }
    }

    // 3. Logica de Export
    function exportCode() {
        const code = editor.getValue();
        const lang = document.getElementById('langSelect').value;
        const ext = (lang === "51") ? ".cs" : ".cpp";
        const blob = new Blob([code], { type: 'text/plain' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = "mentora_algoritm" + ext;
        a.click();
    }

    // 4. Logica de Compilare (Placeholder pentru API)
    async function compileCode() {
    const terminal = document.getElementById('terminal');
    terminal.innerHTML = "<div class='text-warning animate-pulse'>[BUILD] Se trimite codul către backend-ul securizat Mentora...</div>";

    try {
        // Trimitem codul local către serverul nostru de C#
        const response = await fetch('@Url.Action("CompileAlgorithm", "CodeLab")', {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded"
            },
            body: new URLSearchParams({
                sourceCode: editor.getValue(),
                languageId: document.getElementById('langSelect').value
            })
        });

        const result = await response.json();
        terminal.innerHTML = "";

        if (result.success === false) {
            terminal.innerHTML = `<div class='text-danger'>[ERROR]: ${result.message}</div>`;
            return;
        }

        // Analizăm răspunsul primit de la serverul nostru, provenit de la Judge0
        if (result.stdout) {
            terminal.innerHTML += `<div class='text-success fw-bold'>[OUTPUT]:</div><pre class='text-white' style='white-space: pre-wrap;'>${result.stdout}</pre>`;
        }
        if (result.compile_output) {
            terminal.innerHTML += `<div class='text-danger fw-bold'>[COMPILATION ERROR]:</div><pre class='text-danger' style='white-space: pre-wrap;'>${result.compile_output}</pre>`;
        }
        if (result.stderr) {
            terminal.innerHTML += `<div class='text-danger fw-bold'>[RUNTIME ERROR]:</div><pre class='text-danger' style='white-space: pre-wrap;'>${result.stderr}</pre>`;
        }

        // În caz de execuție de succes fără stdout (ex: programe simple fără afișare)
        if (!result.stdout && !result.compile_output && !result.stderr) {
            terminal.innerHTML += `<div class='text-muted'>[SUCCESS]: Programul s-a executat dar nu a returnat nimic în consolă.</div>`;
        }

        terminal.innerHTML += `<div class='mt-3 small text-muted border-top pt-2'>Timp Execuție: ${result.time || 0}s | Memorie: ${result.memory || 0}KB</div>`;

    } catch (err) {
        terminal.innerHTML = `<div class='text-danger'>[Eroare conexiune server local]: ${err.message}</div>`;
    }
}

</script>