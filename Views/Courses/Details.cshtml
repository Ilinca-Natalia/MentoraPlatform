﻿@using Microsoft.AspNet.Identity
@model MentoraPlatform.Models.Course

@* Font Awesome & Select2 CSS *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

@{
    ViewBag.Title = Model.Title;
    var currentUserId = User.Identity.GetUserId();
    bool isAdmin = User.IsInRole("Admin");
    bool isTeacherOwner = Request.IsAuthenticated && (currentUserId == Model.TeacherId);
    bool isOwner = isTeacherOwner || isAdmin;

    // Un elev are acces dacă este înscris. Profesorul/Adminul are acces mereu.
    bool isEnrolled = Model.EnrolledStudents != null && Model.EnrolledStudents.Any(s => s.Id == currentUserId);
    bool hasAccess = isEnrolled || isOwner;

    var completedIds = ViewBag.CompletedLessonIds as List<int> ?? new List<int>();

    // Obținem cererea activă de înscriere transmisă de utilizator
    var enrollmentRequest = ViewBag.EnrollmentRequest as MentoraPlatform.Models.EnrollmentRequest;
}

<style>
    .select2-container--default .select2-selection--single {
        border-radius: 8px !important;
        height: 38px !important;
        border: 1px solid #ced4da !important;
    }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 36px !important;
            padding-left: 12px !important;
            text-align: left !important;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            height: 36px !important;
        }

    .select2-dropdown {
        border-radius: 8px !important;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .custom-dropdown-container {
        position: relative;
        display: inline-block;
    }

    .custom-dropdown-menu {
        display: none;
        position: absolute;
        right: 0;
        top: 100%;
        background-color: #ffffff;
        min-width: 160px;
        box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.15);
        border-radius: 8px;
        padding: 6px 0;
        z-index: 1050;
        border: 1px solid #e2e8f0;
        list-style: none;
        margin: 4px 0 0 0;
    }

        .custom-dropdown-menu.show-menu {
            display: block !important;
        }

    .custom-dropdown-item {
        color: #2d3748;
        padding: 8px 16px;
        text-decoration: none;
        display: block;
        font-size: 14px;
        transition: background-color 0.2s;
        text-align: left;
    }

        .custom-dropdown-item:hover {
            background-color: #f7fafc;
            color: #1a202c;
        }

    .custom-dropdown-divider {
        height: 1px;
        margin: 4px 0;
        overflow: hidden;
        background-color: #e2e8f0;
    }
</style>

<div class="container mt-4 pb-5">
    @* --- MESAJE NOTIFICARE --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-pill px-4 shadow-sm text-start" role="alert">
            <i class="fa fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" data-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-pill px-4 shadow-sm text-start" role="alert">
            <i class="fa fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" data-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* --- HEADER CURS --- *@
    <div class="p-5 mb-4 bg-dark text-white rounded-4 shadow-lg text-start" style="background: linear-gradient(45deg, #1a2a6c, #b21f1f, #fdbb2d);">
        <h1 class="display-4 fw-bold">@Model.Title</h1>
        <p class="fs-5 mt-3"><i class="fa fa-user-tie me-2 text-info"></i>Mentor: @(Model.Teacher?.FirstName) @(Model.Teacher?.LastName)</p>
    </div>

    <div class="row">
        <div class="col-lg-8 text-start">
            @* --- DESCRIERE --- *@
            <div class="card border-0 shadow-sm mb-4 rounded-3">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3 text-primary"><i class="fa fa-align-left me-2"></i>Descriere</h4>
                    <p class="text-secondary" style="white-space: pre-line;">@Model.Description</p>
                </div>
            </div>

            @* --- CARD INTERACTIV DE ÎNSCRIERE / STATUS SOLICITARE --- *@
            @if (!hasAccess && User.IsInRole("Student"))
            {
                <div class="card border-warning bg-warning bg-opacity-10 text-start p-4 rounded-3 mb-4 shadow-sm border-2">
                    <div class="d-flex align-items-center">
                        @if (enrollmentRequest == null)
                        {
                            <!-- Studentul nu a trimis nicio solicitare în baza de date -->
                            <i class="fa fa-lock text-warning fa-3x me-3"></i>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">Curs Privat</h5>
                                <p class="text-secondary mb-3 small">Nu sunteți înscris la această disciplină. Trimiteți o solicitare de înscriere pentru a debloca conținutul lecțiilor.</p>
                                @using (Html.BeginForm("Enroll", "Courses", new { id = Model.Id }, FormMethod.Post, new { @class = "m-0" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-warning btn-md rounded-pill fw-bold px-4 shadow-sm">
                                        <i class="fa fa-user-plus me-2"></i> Doresc să mă înscriu la curs
                                    </button>
                                }
                            </div>
                        }
                        else if (enrollmentRequest.IsPending)
                        {
                            <!-- Solicitare trimisă, în așteptare de confirmare din partea prof-ului -->
                            <i class="fa fa-clock text-warning fa-3x me-3 animate-pulse"></i>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">Solicitare în curs de aprobare</h5>
                                <p class="text-secondary mb-0 small">Cererea dumneavoastră a fost înregistrată la data de @enrollmentRequest.RequestDate.ToString("dd.MM.yyyy HH:mm") și se află în curs de analiză de către mentorul cursului.</p>
                            </div>
                        }
                        else if (!enrollmentRequest.IsApproved)
                        {
                            <!-- Solicitarea a fost respinsă de profesor, dar îi dăm voie să retransmită cererea -->
                            <i class="fa fa-times-circle text-danger fa-3x me-3"></i>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">Solicitare Respinsă</h5>
                                <p class="text-secondary mb-3 small">Solicitarea dumneavoastră anterioară de înscriere a fost respinsă. Puteți retransmite o cerere nouă dacă este necesar.</p>
                                @using (Html.BeginForm("Enroll", "Courses", new { id = Model.Id }, FormMethod.Post, new { @class = "m-0" }))
                                {
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-md rounded-pill fw-bold px-4 shadow-sm">
                                        <i class="fa fa-redo me-2"></i> Retrimite Solicitare
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @* --- PROGRAMA (CURRICULUM) --- *@
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold mb-0"><i class="fa fa-stream text-primary me-2"></i>Curriculum</h4>
                @if (isOwner)
                {
                    <a href="@Url.Action("Create", "Lessons", new { courseId = Model.Id })" class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                        <i class="fa fa-plus me-1"></i> Adaugă Lecție
                    </a>
                }
            </div>

            <div class="list-group shadow-sm rounded-3">
                @if (Model.Lessons != null && Model.Lessons.Any())
                {
                    foreach (var lesson in Model.Lessons.OrderBy(l => l.Id))
                    {
                        bool isDone = completedIds.Contains(lesson.Id);
                        <div class="list-group-item d-flex justify-content-between align-items-center p-3" style="overflow: visible;">
                            <div class="d-flex align-items-center text-start">
                                <i class="fa @(isDone ? "fa-check-circle text-success" : "fa-circle-play text-primary") fs-5 me-3"></i>
                                <h6 class="mb-0 @(isDone ? "text-muted text-decoration-line-through" : "fw-bold")">@lesson.Title</h6>
                            </div>

                            <div class="d-flex gap-2 align-items-center">
                                @if (hasAccess)
                                {
                                    <a href="@Url.Action("Details", "Lessons", new { id = lesson.Id })" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">Învață</a>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted rounded-pill"><i class="fa fa-lock me-1"></i> Privat</span>
                                }

                                @if (isOwner)
                                {
                                    <div class="custom-dropdown-container">
                                        <button class="btn btn-link text-muted p-1 js-dropdown-trigger"
                                                type="button"
                                                data-target-menu="menu-@lesson.Id">
                                            <i class="fa fa-ellipsis-v fs-5" style="pointer-events: none;"></i>
                                        </button>
                                        <ul class="custom-dropdown-menu" id="menu-@lesson.Id">
                                            <li>
                                                <a class="custom-dropdown-item" href="@Url.Action("Edit", "Lessons", new { id = lesson.Id })">
                                                    <i class="fa fa-edit me-2 text-primary"></i> Editează
                                                </a>
                                            </li>
                                            <li><div class="custom-dropdown-divider"></div></li>
                                            <li>
                                                <a class="custom-dropdown-item text-danger" href="@Url.Action("Delete", "Lessons", new { id = lesson.Id })" onclick="return confirm('Sigur doriți să ștergeți această lecție?')">
                                                    <i class="fa fa-trash me-2"></i> Șterge
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="list-group-item text-center py-4 text-muted small">Nu există lecții adăugate încă.</div>
                }
            </div>
        </div>

        @* --- SIDEBAR --- *@
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 text-center sticky-top" style="top: 20px; z-index: 10;">
                @if (isOwner)
                {
                    <div class="text-start p-3 bg-light rounded-3 border">
                        <h6 class="fw-bold mb-3 text-primary"><i class="fa fa-user-plus me-2"></i>Select Students</h6>

                        @using (Html.BeginForm("AddStudent", "Courses", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            @Html.Hidden("courseId", Model.Id)

                            <div class="mb-3">
                                <select name="studentEmail" id="selectStudentAI" class="form-control">
                                    <option value="">Select Students</option>
                                    @if (ViewBag.RawStudentList != null)
                                    {
                                        foreach (var student in (IEnumerable<MentoraPlatform.Models.ApplicationUser>)ViewBag.RawStudentList)
                                        {
                                            <option value="@student.Email">@student.FirstName @student.LastName</option>
                                        }
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm w-100 rounded-pill fw-bold shadow-sm">
                                ÎNSCRIE ACUM
                            </button>
                        }

                        <button class="btn btn-outline-dark btn-sm w-100 rounded-pill fw-bold mt-3 shadow-sm"
                                type="button"
                                data-bs-toggle="collapse"
                                data-toggle="collapse"
                                data-bs-target="#listElevi"
                                data-target="#listElevi">
                            <i class="fa fa-users me-2"></i>Elevi înscriși (@(Model.EnrolledStudents?.Count ?? 0))
                        </button>

                        <div class="collapse mt-2" id="listElevi">
                            <div class="card card-body p-2 border-0 bg-white shadow-sm" style="max-height: 200px; overflow-y: auto;">
                                @if (Model.EnrolledStudents != null && Model.EnrolledStudents.Any())
                                {
                                    foreach (var s in Model.EnrolledStudents)
                                    {
                                        <div class="d-flex justify-content-between align-items-center border-bottom py-2 px-1">
                                            <small class="fw-bold text-dark">@s.FirstName @s.LastName</small>
                                            @using (Html.BeginForm("DeleteStudent", "Courses", FormMethod.Post, new { @class = "d-inline" }))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="courseId" value="@Model.Id" />
                                                <input type="hidden" name="studentId" value="@s.Id" />
                                                <button type="submit" class="btn btn-link text-danger p-0 ms-2" onclick="return confirm('Elimini elevul?')">
                                                    <i class="fa fa-trash-can fs-6"></i>
                                                </button>
                                            }
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }

                @* --- AFISARE STATUT PENTRU ELEVII INSCRISI --- *@
                @if (isEnrolled)
                {
                    <div class="text-start p-3 bg-success bg-opacity-10 rounded-3 border border-success border-opacity-20 mb-3">
                        <span class="small text-success d-block fw-bold"><i class="fa fa-check-circle me-1"></i> Sunteți membru activ al cursului</span>
                    </div>
                }

                @* --- BUTONUL DE QUIZ (CURAT, REDENUMIT DIN TESTARE AI) --- *@
                @if (hasAccess)
                {
                    <div class="mt-4">
                        <p class="text-start mb-2 small"><i class="fa fa-circle-question text-success me-2"></i> Evaluare disponibilă</p>
                        <a href="@Url.Action("Index", "Quizzes", new { courseId = Model.Id })" class="btn btn-warning w-100 rounded-pill fw-bold shadow-sm py-2 text-dark">
                            <i class="fa fa-pencil-alt me-2"></i> Quiz
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#selectStudentAI').select2({
                placeholder: "Select Students",
                allowClear: true,
                width: '100%'
            });

            $(document).on('click', '.js-dropdown-trigger', function (e) {
                e.stopPropagation();

                var targetMenuId = $(this).attr('data-target-menu');
                var targetMenu = $('#' + targetMenuId);

                if (targetMenu.hasClass('show-menu')) {
                    targetMenu.removeClass('show-menu');
                } else {
                    $('.custom-dropdown-menu').removeClass('show-menu');
                    targetMenu.addClass('show-menu');
                }
            });

            $(document).on('click', function () {
                $('.custom-dropdown-menu').removeClass('show-menu');
            });
        });
    </script>
}