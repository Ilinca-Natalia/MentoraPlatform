@model MentoraPlatform.Models.ApplicationUser

@{
    ViewBag.Title = "Eliminare Utilizator";
}

<div class="container mt-5 text-start">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="p-4 text-center bg-light border-bottom">
                    <div class="d-inline-flex justify-content-center align-items-center bg-danger bg-opacity-10 text-danger rounded-circle p-3 mb-3" style="width: 70px; height: 70px;">
                        <i class="fa fa-user-minus fa-2x"></i>
                    </div>
                    <h3 class="fw-bold text-dark m-0">Confirmare Eliminare</h3>
                    <p class="text-muted small mt-2">Această acțiune este ireversibilă.</p>
                </div>

                <div class="card-body p-4 text-center">
                    <p class="text-secondary mb-1 small fw-bold">Ștergere utilizator:</p>
                    <h4 class="fw-bold text-dark mb-4">@Model.FirstName @Model.LastName</h4>

                    <div class="p-3 bg-light rounded-3 text-start border-start border-danger border-4 mb-4">
                        <p class="text-muted small mb-0">Toate datele asociate (cursuri, note, istoric) vor fi șterse din baza de date.</p>
                    </div>

                    <div class="d-flex justify-content-center gap-2">
                        @using (Html.BeginForm("Delete", "Users", new { id = Model.Id }, FormMethod.Post, new { @class = "flex-fill" }))
                        {
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold py-2 shadow-sm">
                                <i class="fas fa-trash-alt me-1"></i> Șterge Definitiv
                            </button>
                        }
                        <a href="@Url.Action("Index")" class="btn btn-outline-secondary flex-fill rounded-pill fw-bold py-2">
                            Anulează
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-danger {
        background-color: #e11d48 !important;
        border-color: #e11d48 !important;
        transition: all 0.2s;
    }

        .btn-danger:hover {
            background-color: #be123c !important;
            border-color: #be123c !important;
        }
</style>