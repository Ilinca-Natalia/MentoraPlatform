@model IEnumerable<MentoraPlatform.Models.ApplicationUser>

@{
    ViewBag.Title = "Gestionare Utilizatori";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-danger text-white py-3 d-flex justify-content-between align-items-center">
            <h3 class="m-0"><i class="fa fa-users-cog me-2"></i>Control Utilizatori</h3>
            <span class="badge bg-white text-danger">Total: @Model.Count()</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Nume Complet</th>
                            <th>Email</th>
                            <th class="text-center">Rol Sistem</th>
                            <th class="text-center">Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@user.FirstName @user.LastName</div>
                                </td>
                                <td>@user.Email</td>
                                <td class="text-center">
                                    @* Identificăm rolul. În ASP.NET Identity, Roles este o colecție de RoleID *@
                                    @if (User.IsInRole("Admin"))
                                    {
                                        @* Verificăm rolul utilizatorului din rândul curent folosind UserManager sau logica de email pt. demo *@
                                        if (user.Email.Contains("admin"))
                                        {
                                            <span class="badge bg-danger px-3 py-2 text-uppercase">Admin</span>
                                        }
                                        else if (user.Email.Contains("profesor") || user.Email.Contains("teacher"))
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 text-uppercase">Profesor</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary px-3 py-2 text-uppercase">Student</span>
                                        }
                                    }
                                </td>
                                <td class="text-center">
                                    @if (user.Email != User.Identity.Name)
                                    {
                                        <a href="@Url.Action("Delete", new { id = user.Id })" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                                            <i class="fa fa-user-times me-1"></i> Elimină
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border px-3 py-2">Contul Tău</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>