@model IEnumerable<MentoraPlatform.Models.QuizResult>

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h3 class="fw-bold text-dark m-0"><i class="fa fa-graduation-cap text-info me-2"></i>Notele Mele</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Curs</th>
                            <th>Test</th>
                            <th>Data Susținerii</th>
                            <th class="text-center">Notă</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var res in Model)
                        {
                            <tr>
                                <td class="fw-bold">@res.Quiz.Course.Title</td>
                                <td>@res.Quiz.Title</td>
                                <td>@res.DateTaken.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-center">
                                    <span class="fs-5 fw-bold @(res.Score >= 5 ? "text-success" : "text-danger")">@res.Score</span>
                                </td>
                                <td>
                                    @if (res.Score >= 5)
                                    {
                                        <span class="badge bg-success rounded-pill">Promovat</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill">Respins</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>