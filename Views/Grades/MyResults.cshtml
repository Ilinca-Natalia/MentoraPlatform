@model IEnumerable<MentoraPlatform.Models.QuizResult>

@{
    ViewBag.Title = "Notele Mele";

    // Calculăm statistici de bază direct în Razor
    var totalTests = Model.Count();
    var averageScore = totalTests > 0 ? Math.Round(Model.Average(r => r.Score), 2) : 0;
    var passedCount = Model.Count(r => r.Score >= 5);
    var passRate = totalTests > 0 ? Math.Round(((double)passedCount / totalTests) * 100, 0) : 0;

    // Sortăm cronologic pentru a randa corect graficul de evoluție
    var chronologicalGrades = Model.OrderBy(r => r.DateTaken).ToList();
}

<!-- Chart.js CDN pentru grafice interactive de top -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-4 pb-5 text-start">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1"><i class="fa fa-graduation-cap text-primary me-2"></i>Notele Mele</h2>
            <p class="text-muted mb-0">Monitorizați-vă evoluția academică și rezultatele testelor susținute.</p>
        </div>
    </div>

    <!-- 1. DASHBOARD CARDURI STATISTICE -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-uppercase text-muted small fw-bold">Media Generală</span>
                        <h2 class="fw-bold mt-1 mb-0 @(averageScore >= 5 ? "text-success" : "text-danger")">@averageScore</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-circle">
                        <i class="fa fa-star fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-uppercase text-muted small fw-bold">Teste Susținute</span>
                        <h2 class="fw-bold mt-1 mb-0 text-dark">@totalTests</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 text-info p-3 rounded-circle">
                        <i class="fa fa-clipboard-check fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <span class="text-uppercase text-muted small fw-bold">Rată Promovabilitate</span>
                        <h2 class="fw-bold mt-1 mb-0 text-success">@passRate%</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 text-success p-3 rounded-circle">
                        <i class="fa fa-chart-pie fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- 2. DIAGRAMĂ EVOLUȚIE NOTE -->
        <div class="col-lg-12">
            <div class="card border-0 shadow-sm rounded-3 p-4 bg-white">
                <h5 class="fw-bold text-dark mb-4"><i class="fa fa-chart-line text-primary me-2"></i>Grafic de Progres și Evoluție a Notelor</h5>
                @if (totalTests > 0)
                {
                    <div style="height: 280px; position: relative;">
                        <canvas id="gradeEvolutionChart"></canvas>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fa fa-chart-bar fa-3x mb-3 text-muted"></i>
                        <p>Evoluția notelor va apărea aici după ce veți susține primul test.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 3. TABEL NOTELE MELE -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="fw-bold text-dark m-0"><i class="fa fa-list-ul text-primary me-2"></i>Istoric Detaliat Rezultate</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Curs</th>
                            <th>Test</th>
                            <th>Data Susținerii</th>
                            <th class="text-center">Notă obținută</th>
                            <th class="pe-4">Status evaluare</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var res in Model.OrderByDescending(r => r.DateTaken))
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@res.Quiz.Course.Title</td>
                                    <td>@res.Quiz.Title</td>
                                    <td class="text-muted">@res.DateTaken.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <span class="fs-5 fw-bold @(res.Score >= 5 ? "text-success" : "text-danger")">@res.Score</span>
                                    </td>
                                    <td class="pe-4">
                                        @if (res.Score >= 5)
                                        {
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2"><i class="fa fa-check-circle me-1"></i> Promovat</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2"><i class="fa fa-times-circle me-1"></i> Respins</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    Nu ați susținut niciun test până în prezent.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (totalTests > 0)
{
    @section scripts {
        <script>
            // Datele pregătite pentru axa X (Denumire test) și axa Y (Notă)
            var labels = [
                @foreach (var res in chronologicalGrades) {
                    @Html.Raw("'" + res.Quiz.Title + "',")
                }
            ];

            var scores = [
                @foreach (var res in chronologicalGrades) {
                    @res.Score.ToString().Replace(",", ".")@Html.Raw(",")
                }
            ];

            var ctx = document.getElementById('gradeEvolutionChart').getContext('2d');
            var myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Nota obținută',
                        data: scores,
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.08)',
                        borderWidth: 3,
                        pointBackgroundColor: '#2563eb',
                        pointBorderColor: '#ffffff',
                        pointBorderWidth: 2,
                        pointRadius: 6,
                        pointHoverRadius: 8,
                        fill: true,
                        tension: 0.35
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            min: 0,
                            max: 10,
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });
        </script>
    }
}