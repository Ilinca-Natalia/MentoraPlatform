@model IEnumerable<MentoraPlatform.Models.StudentRiskViewModel>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Analiză Risc Abandon - @ViewBag.CourseTitle</h2>
        <a href="@Url.Action("StudentsGrades")" class="btn btn-outline-secondary rounded-pill">Înapoi la Catalog</a>
    </div>

    <table class="table table-hover shadow-sm bg-white rounded-3">
        <thead class="table-dark">
            <tr>
                <th>Student</th>
                <th>Progres</th>
                <th>Media</th>
                <th>Inactivitate (zile)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsAtRisk ? "table-danger" : "")">
                    <td class="fw-bold">@item.FullName</td>
                    <td>@item.ProgressPercentage%</td>
                    <td>@item.AverageScore</td>
                    <td>@item.DaysSinceLastActivity zile</td>
                    <td>
                        @if (item.IsAtRisk)
                        {<span class="badge bg-danger">Risc!</span> }
                        else
                        { <span class="badge bg-success">Activ</span>}
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>