@model MentoraPlatform.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Recuperare Parolă";
}

<div class="container py-5 text-start">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg p-4 p-md-5 rounded-4 bg-white">
                <!-- Iconiță cheie securitate -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex justify-content-center align-items-center bg-primary bg-opacity-10 text-primary rounded-circle p-3 mb-3" style="width: 70px; height: 70px;">
                        <i class="fas fa-key fa-2x"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">Ați uitat parola?</h3>
                    <p class="text-muted small">Introduceți adresa de email pentru a primi instrucțiunile de resetare.</p>
                </div>

                @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post, new { role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary("", new { @class = "alert alert-danger rounded-3 py-2 small" })

                    <!-- Câmp Email stilizat -->
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary small uppercase"><i class="fas fa-envelope me-1"></i> Adresă Email</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control form-control-lg border-2 rounded-3 fs-6", placeholder = "nume@exemplu.com" })
                    </div>

                    <!-- Buton Submit -->
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-2.5 shadow-sm transition-hover mb-3">
                        <i class="fas fa-paper-plane me-2"></i> Trimite Link Recuperare
                    </button>

                    <div class="text-center">
                        <a href="@Url.Action("Login", "Account")" class="text-decoration-none small fw-bold text-primary">
                            <i class="fas fa-arrow-left me-1"></i> Înapoi la Conectare
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(13, 110, 253, 0.15) !important;
        }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }
</style>