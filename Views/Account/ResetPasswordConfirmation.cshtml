@{
    ViewBag.Title = "Parolă Schimbată";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 text-center">
            <div class="card border-0 shadow-lg p-5 rounded-4 bg-white">
                <!-- Iconiță Succes mare de tip lacăt descuiat -->
                <div class="d-inline-flex justify-content-center align-items-center bg-success bg-opacity-10 text-success rounded-circle p-4 mb-4" style="width: 100px; height: 100px;">
                    <i class="fas fa-unlock-alt fa-4x"></i>
                </div>

                <h2 class="fw-bold text-dark mb-2">Parolă Actualizată!</h2>
                <p class="text-secondary mb-4">Noua dumneavoastră parolă a fost configurată și stocată în deplină siguranță. Vă puteți conecta acum la cont.</p>

                <!-- Buton direct spre autentificare -->
                <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-2.5 shadow-sm transition-hover">
                    <i class="fas fa-sign-in-alt me-2"></i> Conectează-te cu noua parolă
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(13, 110, 253, 0.15) !important;
        }
</style>