@model MentoraPlatform.Models.ResetPasswordViewModel
@{
    ViewBag.Title = "Resetare Parolă";
}

<div class="container py-5 text-start">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg p-4 p-md-5 rounded-4 bg-white">

                <!-- Antet Card -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex justify-content-center align-items-center bg-warning bg-opacity-10 text-warning rounded-circle p-3 mb-3" style="width: 70px; height: 70px;">
                        <i class="fas fa-user-shield fa-2x"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-1">Setare Parolă Nouă</h3>
                    <p class="text-muted small">Introduceți email-ul contului și noua parolă dorită.</p>
                </div>

                @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post, new { role = "form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(model => model.Code)
                    @Html.ValidationSummary("", new { @class = "alert alert-danger rounded-3 py-2 small" })

                    <!-- Câmp Email -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small uppercase"><i class="fas fa-envelope me-1"></i> Confirmați Email-ul</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control border-2 rounded-3", placeholder = "nume@exemplu.com" })
                    </div>

                    <!-- Câmp Parolă Nouă -->
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary small uppercase"><i class="fas fa-lock me-1"></i> Parolă Nouă</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control border-2 rounded-3", placeholder = "Minim 6 caractere" })
                    </div>

                    <!-- Confirmare Parolă -->
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary small uppercase"><i class="fas fa-lock me-1"></i> Confirmare Parolă</label>
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control border-2 rounded-3", placeholder = "Reintroduceți noua parolă" })
                    </div>

                    <!-- Buton Submit -->
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-2.5 shadow-sm transition-hover">
                        <i class="fas fa-save me-2"></i> Salvează Noua Parolă
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(13, 110, 253, 0.15) !important;
        }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }
</style>