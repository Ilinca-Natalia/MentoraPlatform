@model MentoraPlatform.Models.Quiz
@{ ViewBag.Title = "Editare Completă Test"; }

<div class="container mt-4 mb-5">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Id)

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-dark text-white p-4">
                <h3 class="mb-0">Editare Test: @Model.Title</h3>
                <p class="mb-0 opacity-75">Curs: @Model.Course.Title</p>
            </div>
            <div class="card-body p-4">
                <div class="mb-4">
                    <label class="fw-bold">Titlu General Test:</label>
                    @Html.TextBoxFor(m => m.Title, new { @class = "form-control form-control-lg" })
                </div>

                <hr />
                <h4 class="mb-4 text-primary">Întrebări și Răspunsuri</h4>

                @foreach (var question in Model.Questions)
                {
                    <div class="card mb-4 border-start border-primary border-4 shadow-sm">
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="small fw-bold text-muted uppercase">Întrebare:</label>
                                <input type="text" name="question_@question.Id" value="@question.Text" class="form-control fw-bold" />
                            </div>

                            <div class="row g-3">
                                @foreach (var choice in question.Choices)
                                {
                                    <div class="col-md-6">
                                        <div class="input-group">
                                            <div class="input-group-text bg-white">
                                                <input type="checkbox" name="correct_@choice.Id" value="true" @(choice.IsCorrect ? "checked" : "") class="form-check-input" />
                                                <input type="hidden" name="correct_@choice.Id" value="false" />
                                            </div>
                                            <input type="text" name="choice_@choice.Id" value="@choice.AnswerText" class="form-control" />
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }

                <div class="d-flex gap-3 mt-5">
                    <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm rounded-pill fw-bold">
                        <i class="fa fa-save me-2"></i>SALVEAZĂ MODIFICĂRILE
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-lg px-5 rounded-pill">Anulează</a>
                </div>
            </div>
        </div>
    }
</div>