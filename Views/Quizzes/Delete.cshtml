@model MentoraPlatform.Models.Quiz

@{
    ViewBag.Title = "Ștergere Test";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg overflow-hidden">
                <div class="card-header bg-danger text-white py-3 text-center">
                    <h4 class="m-0 fw-bold"><i class="fa fa-exclamation-triangle me-2"></i>Confirmă Ștergerea</h4>
                </div>
                <div class="card-body p-5 text-center">
                    <p class="lead mb-4">Ești sigur că vrei să ștergi testul:</p>
                    <h2 class="fw-bold text-dark mb-3">"@Model.Title"</h2>
                    <div class="badge bg-soft-danger text-danger border border-danger px-3 py-2 mb-4">
                        <i class="fa fa-book me-1"></i> Curs: @Model.Course.Title
                    </div>

                    <div class="alert alert-warning border-0 small text-start">
                        <i class="fa fa-info-circle me-2"></i>
                        <strong>Atenție:</strong> Ștergerea acestui test va elimina și toate rezultatele (notele) studenților care l-au susținut deja.
                    </div>
                </div>
                <div class="card-footer bg-light p-4 d-flex justify-content-center gap-3">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-lg px-5 fw-bold shadow-sm">
                            DA, ȘTERGE
                        </button>
                    }
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-lg px-5">ANULEAZĂ</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-danger {
        background-color: rgba(220, 53, 69, 0.1);
    }
</style>