@model MentoraPlatform.Models.Lesson

@{
    ViewBag.Title = "Configurare Lecție Nouă";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white p-4">
                    <h3 class="mb-0 fw-bold"><i class="fa fa-plus-circle me-2"></i>Creează o experiență nouă de învățare</h3>
                    <p class="mb-0 opacity-75">Curs: @ViewBag.CourseTitle</p>
                </div>
                <div class="card-body p-5">
                    @using (Html.BeginForm("Create", "Lessons", FormMethod.Post, new { enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("CourseId", (int)ViewBag.CourseId)

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary uppercase small">Titlul Lecției</label>
                            @Html.TextBoxFor(m => m.Title, new { @class = "form-control form-control-lg border-2", placeholder = "Ex: 01. Introducere în algoritmi..." })
                            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold text-secondary uppercase small">Link Video (YouTube/Vimeo)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light"><i class="fa fa-play-circle"></i></span>
                                    @Html.TextBoxFor(m => m.VideoUrl, new { @class = "form-control", placeholder = "https://www.youtube.com/watch?v=..." })
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary uppercase small">Conținutul Lecției</label>
                            @Html.TextAreaFor(m => m.Content, new { @id = "editor", @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.Content, "", new { @class = "text-danger" })
                        </div>

                        <div class="mb-5">
                            <label class="form-label fw-bold text-secondary uppercase small">Materiale Descărcabile (.pdf, .zip, .docx)</label>
                            <input type="file" name="attachments" multiple class="form-control border-dashed p-4" />
                            <small class="text-muted">Poți selecta mai multe fișiere simultan din calculator.</small>
                        </div>

                        <div class="d-flex gap-3 pt-3 border-top">
                            <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow">
                                <i class="fa fa-save me-2"></i>SALVEAZĂ LECȚIA
                            </button>
                            <a href="@Url.Action("Details", "Courses", new { id = (int)ViewBag.CourseId })" class="btn btn-outline-secondary btn-lg px-4">Anulează</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-dashed {
        border: 2px dashed #dee2e6 !important;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13,110,253,.1);
    }
</style>

@section Scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        // Această linie transformă automat textarea-ul cu id="editor" într-un editor stil Word
        CKEDITOR.replace('editor', {
            // Putem adăuga setări extra pentru a face editorul mai prietenos
            toolbar: [
                { name: 'basicstyles', items: ['Bold', 'Italic', 'Underline', 'Strike', '-', 'RemoveFormat'] },
                { name: 'paragraph', items: ['NumberedList', 'BulletedList', '-', 'Outdent', 'Indent', '-', 'Blockquote'] },
                { name: 'styles', items: ['Format', 'Font', 'FontSize'] },
                { name: 'colors', items: ['TextColor', 'BGColor'] },
                { name: 'insert', items: ['Table', 'HorizontalRule', 'SpecialChar'] }
            ],
            height: '400px'
        });
    </script>
}