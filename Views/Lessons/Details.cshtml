@using Microsoft.AspNet.Identity
@model MentoraPlatform.Models.Lesson

@{
    ViewBag.Title = Model.Title;
    bool isCompleted = ViewBag.IsCompleted ?? false;
    // Verificăm dacă utilizatorul curent este profesorul cursului sau Admin
    bool isProfessorOrAdmin = User.IsInRole("Admin") || (Model.Course != null && User.Identity.GetUserId() == Model.Course.TeacherId);
}

<div class="container mt-4 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            @* 1. Breadcrumbs pentru navigare ușoară *@
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Courses")" class="text-decoration-none">Cursuri</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Details", "Courses", new { id = Model.CourseId })" class="text-decoration-none">@Model.Course.Title</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
                </ol>
            </nav>

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-4 border-0 d-flex justify-content-between align-items-center px-5">
                    <div>
                        <span class="text-uppercase text-muted small fw-bold">Lecție</span>
                        <h1 class="fw-bold text-dark m-0">@Model.Title</h1>
                    </div>
                    @if (isCompleted)
                    {
                        <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm">
                            <i class="fa fa-check-circle me-1"></i> Finalizată
                        </span>
                    }
                </div>

                @* 2. Secțiune Video (Dacă există URL) *@
                @if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <div class="ratio ratio-16x9 bg-dark shadow-inner">
                        <iframe src="@Model.VideoUrl" title="Lesson Video" allowfullscreen></iframe>
                    </div>
                }

                <div class="card-body px-5 py-5 bg-white">
                    @* --- SECȚIUNE GENERARE AI (DOAR PENTRU PROFESOR) --- *@
                    @if (isProfessorOrAdmin)
                    {
                        <div id="aiSection" class="alert alert-purple d-flex flex-column flex-md-row justify-content-between align-items-md-center shadow-sm mb-5 border-0 p-4 rounded-4">
                            <div class="mb-3 mb-md-0">
                                <h5 class="mb-1 fw-bold text-purple"><i class="fa fa-robot me-2"></i>Mentora AI Assistant</h5>
                                <p class="mb-0 text-muted small">Folosește inteligența artificială pentru a extrage întrebări din textul de mai jos.</p>
                            </div>
                            @using (Html.BeginForm("PreviewGeneratedQuiz", "Quizzes", FormMethod.Post, new { id = "aiForm", onsubmit = "return showAiLoading()" }))
                            {
                                @Html.AntiForgeryToken()
                                @Html.Hidden("lessonId", Model.Id)
                                <button type="submit" id="aiBtn" class="btn btn-purple px-4 fw-bold shadow-sm rounded-pill transition-hover">
                                    <i class="fa fa-magic me-2"></i>Generează Quiz
                                </button>
                            }
                        </div>

                        <div id="aiLoading" class="text-center mb-5" style="display:none;">
                            <div class="spinner-grow text-purple" role="status" style="width: 3rem; height: 3rem;">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <h5 class="mt-3 fw-bold text-purple animate-pulse">AI-ul analizează conținutul lecției...</h5>
                            <p class="text-muted small">Acest proces poate dura până la 10-15 secunde.</p>
                        </div>
                    }

                    @* 3. Conținut Text al Lecției *@
                    <div class="lesson-content mb-5">
                        @Html.Raw(Model.Content)
                    </div>

                    @* 4. Secțiune Fișiere Atașate *@
                    @if (Model.LessonAttachments != null && Model.LessonAttachments.Any())
                    {
                        <div class="bg-light p-4 rounded-4 border-0 shadow-sm">
                            <h5 class="fw-bold mb-4 text-dark"><i class="fa fa-paperclip me-2 text-primary"></i>Resurse Descărcabile</h5>
                            <div class="row g-3">
                                @foreach (var file in Model.LessonAttachments)
                                {
                                    <div class="col-md-6">
                                        <a href="@file.FilePath" download="@file.FileName" class="btn btn-white border w-100 text-start d-flex align-items-center p-3 shadow-sm transition-hover rounded-3 text-decoration-none">
                                            <div class="bg-primary bg-opacity-10 p-2 rounded-circle me-3">
                                                <i class="fa fa-file-download text-primary"></i>
                                            </div>
                                            <span class="text-truncate fw-bold text-dark">@file.FileName</span>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @* 5. Footer Navigație *@
                <div class="card-footer bg-white d-flex flex-wrap justify-content-between align-items-center py-4 px-5 border-top gap-3">
                    @Html.ActionLink("Înapoi la Curs", "Details", "Courses", new { id = Model.CourseId }, new { @class = "btn btn-outline-dark rounded-pill px-4 fw-bold" })

                    <div class="d-flex flex-wrap gap-2 align-items-center">
                        @if (User.IsInRole("Student") && !isCompleted)
                        {
                            using (Html.BeginForm("MarkComplete", "Lessons", new { id = Model.Id }, FormMethod.Post, new { @class = "m-0" }))
                            {
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success fw-bold px-4 rounded-pill shadow-sm transition-hover">
                                    <i class="fa fa-check me-1"></i> Am terminat lecția
                                </button>
                            }
                        }

                        <a href="@Url.Action("Index", "CodeLab")" class="btn btn-warning fw-bold rounded-pill px-4 shadow-sm transition-hover text-dark">
                            <i class="fa fa-code me-1"></i> Exersează Cod
                        </a>

                        @if (isProfessorOrAdmin)
                        {
                            <a href="@Url.Action("Edit", "Lessons", new { id = Model.Id })" class="btn btn-outline-primary rounded-pill px-4">
                                <i class="fa fa-edit"></i> Editează
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --purple-main: #8e24aa;
        --purple-light: #f3e5f5;
    }

    .lesson-content {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #2c3e50;
    }

        .lesson-content img {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            margin: 20px 0;
        }

    .alert-purple {
        background-color: var(--purple-light);
        border-left: 6px solid var(--purple-main) !important;
    }

    .text-purple {
        color: var(--purple-main);
    }

    .btn-purple {
        background-color: var(--purple-main);
        color: white;
    }

        .btn-purple:hover {
            background-color: #7b1fa2;
            color: white;
            transform: scale(1.02);
        }

    .btn-white {
        background: white;
        color: #333;
    }

    .transition-hover:hover {
        transform: translateY(-3px);
        transition: all 0.3s ease;
        box-shadow: 0 8px 15px rgba(0,0,0,0.1) !important;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.4;
        }

        100% {
            opacity: 1;
        }
    }

    .animate-pulse {
        animation: pulse 1.8s infinite ease-in-out;
    }

    .shadow-inner {
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.5);
    }
</style>

<script>
    function showAiLoading() {
        const loadingDiv = document.getElementById('aiLoading');
        const aiSection = document.getElementById('aiSection');
        const btn = document.getElementById('aiBtn');

        if (loadingDiv) loadingDiv.style.display = 'block';
        if (aiSection) aiSection.style.display = 'none'; // Ascundem panoul pentru a focaliza pe loading

        return true; // Permitem submit-ul formularului
    }
</script>