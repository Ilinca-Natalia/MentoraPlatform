@model MentoraPlatform.Models.Lesson

@{
    ViewBag.Title = "Editează Lecția";
}

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h2 class="text-primary border-bottom pb-2">Editare: @Model.Title</h2>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.CourseId)

            <div class="mb-3 mt-3">
                @Html.LabelFor(m => m.Title, new { @class = "form-label fw-bold" })
                @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Content, new { @class = "form-label fw-bold" })
                @Html.TextAreaFor(m => m.Content, new { @id = "editor", @class = "form-control" })
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Salvează Modificările</button>
                @Html.ActionLink("Anulează", "Details", "Courses", new { id = Model.CourseId }, new { @class = "btn btn-outline-secondary" })
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        CKEDITOR.replace('editor');
    </script>
}