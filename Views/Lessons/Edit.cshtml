@model MentoraPlatform.Models.Lesson

@{
    ViewBag.Title = "Editează Lecția";
}

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h2 class="text-primary border-bottom pb-2">Editare: @Model.Title</h2>

        <!-- Modificat: Adăugat enctype pentru a suporta încărcarea de fișiere la editare -->
        @using (Html.BeginForm("Edit", "Lessons", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id)
            @Html.HiddenFor(m => m.CourseId)

            <div class="mb-3 mt-3">
                @Html.LabelFor(m => m.Title, new { @class = "form-label fw-bold" })
                @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Link Video (YouTube/Vimeo)</label>
                @Html.TextBoxFor(m => m.VideoUrl, new { @class = "form-control", placeholder = "https://www.youtube.com/watch?v=..." })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Content, new { @class = "form-label fw-bold" })
                @Html.TextAreaFor(m => m.Content, new { @id = "editor", @class = "form-control" })
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold text-secondary small">Adaugă materiale suplimentare noi (.pdf, .zip, .docx)</label>
                <input type="file" name="attachments" multiple class="form-control p-3" />
                <small class="text-muted">Fișierele selectate vor fi adăugate la resursele deja existente ale acestei lecții.</small>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Salvează Modificările</button>
                <a href="@Url.Action("Details", "Courses", new { id = Model.CourseId })" class="btn btn-outline-secondary">Anulează</a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/4.22.1/standard/ckeditor.js"></script>
    <script>
        // Această linie transformă automat textarea-ul cu id="editor" într-un editor stil Word
        CKEDITOR.replace('editor', {
            // Putem adăuga setări extra pentru a face editorul mai prietenos
            toolbar: [
                { name: 'basicstyles', items: ['Bold', 'Italic', 'Underline', 'Strike', '-', 'RemoveFormat'] },
                { name: 'paragraph', items: ['NumberedList', 'BulletedList', '-', 'Outdent', 'Indent', '-', 'Blockquote'] },
                { name: 'styles', items: ['Format', 'Font', 'FontSize'] },
                { name: 'colors', items: ['TextColor', 'BGColor'] },
                { name: 'insert', items: ['Table', 'HorizontalRule', 'SpecialChar'] }
            ],
            height: '400px'
        });
    </script>
}