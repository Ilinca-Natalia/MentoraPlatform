<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - My ASP.NET Application</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark shadow-sm">
        <div class="container">
            @Html.ActionLink("Mentora", "Index", "Courses", new { area = "" }, new { @class = "navbar-brand text-info fw-bold" })

            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                <ul class="nav navbar-nav me-auto">
                    @if (Request.IsAuthenticated)
                    {
                        @* 1. CURSURI - Toată lumea le vede *@
                        <li class="nav-item">
                            @Html.ActionLink("Cursuri", "Index", "Courses", null, new { @class = "nav-link" })
                        </li>

                        @* 2. TESTE - Dinamic în funcție de rol (Modificat pentru QuizzesController) *@
                        <li class="nav-item">
                            @if (User.IsInRole("Student"))
                            {
                                @* Studenții merg la Index pentru a vedea lista de teste disponibile *@
                                @Html.ActionLink("Teste", "Index", "Quizzes", null, new { @class = "nav-link" })
                            }
                            else
                            {
                                @* Profesorii/Adminii merg la Index (sau o metodă de gestionare) *@
                                @Html.ActionLink("Gestionare Teste", "Index", "Quizzes", null, new { @class = "nav-link" })
                            }
                        </li>

                        @* 3. NOTE / REZULTATE *@
                        <li class="nav-item">
                            @if (User.IsInRole("Student"))
                            {
                                @Html.ActionLink("Note", "MyResults", "Grades", null, new { @class = "nav-link" })
                            }
                            else
                            {
                                @Html.ActionLink("Note Elevi", "StudentsGrades", "Grades", null, new { @class = "nav-link" })
                            }
                        </li>

                        @* 4. CODE WRITING - Toată lumea are acces la editor *@
                        <li class="nav-item">
                            @Html.ActionLink("Code Writing", "Index", "CodeLab", null, new { @class = "nav-link text-warning" })
                        </li>

                        @* 5. GESTIONARE UTILIZATORI - Doar pentru Admin *@
                        if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                @Html.ActionLink("Utilizatori", "Index", "Users", null, new { @class = "nav-link" })
                            </li>
                        }
                    }
                </ul>

                @* 6. PARTEA DE CONT (Login/Register sau Salut, User! + Logout) *@
                @Html.Partial("_LoginPartial")
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - Mentora Application</p>
        </footer>
    </div>
    <!-- CSS pentru Chat -->
    <style>
        #chatWidget {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 10000;
            font-family: 'Segoe UI', sans-serif;
        }

        #toggleChat {
            border-radius: 50%;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #6e8efb, #a777e3);
            border: none;
            cursor: pointer;
            color: white;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            transition: transform 0.3s;
        }

            #toggleChat:hover {
                transform: scale(1.1);
            }
        /* Am mutat display: none aici pentru a fi preluat corect */
        #chatWindow {
            display: none;
            width: 350px;
            height: 500px;
            background: white;
            border-radius: 20px;
            bottom: 80px;
            right: 0;
            position: absolute;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            overflow: hidden;
            flex-direction: column;
            border: 1px solid #eee;
        }

        #messages {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            background: #f9f9f9;
        }

        .msg {
            margin-bottom: 15px;
            padding: 10px 15px;
            border-radius: 15px;
            max-width: 80%;
            font-size: 0.9em;
        }

            .msg.user {
                background: #6e8efb;
                color: white;
                align-self: flex-end;
                margin-left: auto;
            }

            .msg.ai {
                background: #e9e9eb;
                color: #333;
            }

        #chatInput {
            border: none;
            padding: 15px;
            border-top: 1px solid #eee;
            outline: none;
        }

        .loader {
            display: none;
            text-align: center;
            font-size: 0.8em;
            color: #888;
            padding: 5px;
        }
    </style>

    <!-- Structura HTML -->
    <div id="chatWidget">
        <button id="toggleChat"><i class="fas fa-comment"></i></button>
        <div id="chatWindow">
            <div id="messages"></div>
            <div id="loader" class="loader">Mentora caută...</div>
            <input type="text" id="chatInput" placeholder="Ce vrei să înveți azi?" />
        </div>
    </div>

    <!-- Script actualizat -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toggleBtn = document.getElementById('toggleChat');
            const win = document.getElementById('chatWindow');
            const input = document.getElementById('chatInput');
            const msgs = document.getElementById('messages');
            const loader = document.getElementById('loader');

            toggleBtn.onclick = () => {
                // Verificăm stilul inline sau computed
                win.style.display = (win.style.display === 'none' || win.style.display === '') ? 'flex' : 'none';
            };

            input.onkeypress = async (e) => {
                if (e.key === 'Enter' && input.value.trim() !== '') {
                    const val = input.value;
                    msgs.innerHTML += `<div class="msg user">${val}</div>`;
                    input.value = '';
                    loader.style.display = 'block';

                    // Verifică dacă există token-ul
                    const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                    const token = tokenInput ? tokenInput.value : '';

                    try {
                        const response = await fetch('/Courses/Chat', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded', '__RequestVerificationToken': token },
                            body: 'message=' + encodeURIComponent(val)
                        });
                        const data = await response.json();
                        loader.style.display = 'none';

                        const replyHtml = (data.url && data.url !== "#") ?
                            `<a href="${data.url}" style="color:#6e8efb; font-weight:bold;">${data.reply}</a>` : data.reply;

                        msgs.innerHTML += `<div class="msg ai">${replyHtml}</div>`;
                        msgs.scrollTop = msgs.scrollHeight;
                    } catch {
                        loader.style.display = 'none';
                        msgs.innerHTML += `<div class="msg ai">Eroare de conexiune.</div>`;
                    }
                }
            };
        });
    </script>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
